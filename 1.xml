    <script>
      // ── responsive.js UnityLoader hatasını önle ──
      window.UnityLoader = { Error: { handler: function() {} } };
    </script>

    <script>
      // ── Part birleştirme sistemi (fetch + XHR) ──
      (function() {
        var splitFiles = {
          "https://cdn.jsdelivr.net/gh/okyesgoogl/sp557xxd@main/Build/Build.data": { parts: 4, prefix: "https://cdn.jsdelivr.net/gh/okyesgoogl/sp557xxd@main/Build/Build.data.part" },
          "https://cdn.jsdelivr.net/gh/okyesgoogl/sp557xxd@main/Build/Build.wasm": { parts: 4, prefix: "https://cdn.jsdelivr.net/gh/okyesgoogl/sp557xxd@main/Build/Build.wasm.part" }
        };

        function findMatch(url) {
          for (var key in splitFiles) {
            if (url.indexOf(key) !== -1 && url.indexOf(".part") === -1) return key;
          }
          return null;
        }

        function downloadAndMerge(matchKey) {
          var info = splitFiles[matchKey];
          console.log("[MERGE] " + matchKey + " yakalandi, " + info.parts + " part indiriliyor...");
          var fetches = [];
          for (var i = 1; i <= info.parts; i++) {
            fetches.push(
              (function(num) {
                return fetch(info.prefix + num).then(function(resp) {
                  if (!resp.ok) throw new Error("[MERGE] part" + num + " HATA: " + resp.status);
                  return resp.arrayBuffer();
                }).then(function(buf) {
                  console.log("[MERGE] " + matchKey + " part" + num + " OK - " + (buf.byteLength / 1048576).toFixed(2) + " MB");
                  return { index: num, buffer: buf };
                });
              })(i)
            );
          }
          return Promise.all(fetches).then(function(results) {
            results.sort(function(a, b) { return a.index - b.index; });
            var totalSize = results.reduce(function(s, r) { return s + r.buffer.byteLength; }, 0);
            var merged = new Uint8Array(totalSize);
            var offset = 0;
            results.forEach(function(r) {
              merged.set(new Uint8Array(r.buffer), offset);
              offset += r.buffer.byteLength;
            });
            console.log("[MERGE] " + matchKey + " tamamlandi! Toplam: " + (totalSize / 1048576).toFixed(2) + " MB");
            return merged;
          });
        }

        // ── Fetch override (wasm için) ──
        var originalFetch = window.fetch;
        window.fetch = function(url, opts) {
          var urlStr = (typeof url === "string") ? url : url.url;
          var matchKey = findMatch(urlStr);
          if (!matchKey) return originalFetch.call(this, url, opts);

          return downloadAndMerge(matchKey).then(function(merged) {
            var ct = matchKey.indexOf(".wasm") !== -1 ? "application/wasm" : "application/octet-stream";
            return new Response(merged.buffer, {
              status: 200,
              headers: { "Content-Type": ct, "Content-Length": merged.byteLength }
            });
          });
        };

        // ── XHR override (data için - Unity loader XHR kullanıyor) ──
        var OrigXHR = XMLHttpRequest;
        var XHRProto = OrigXHR.prototype;
        var origOpen = XHRProto.open;
        var origSend = XHRProto.send;

        XHRProto.open = function(method, url) {
          this._mergeUrl = (typeof url === "string") ? url : "";
          this._mergeMatch = findMatch(this._mergeUrl);
          return origOpen.apply(this, arguments);
        };

        XHRProto.send = function(body) {
          if (!this._mergeMatch) return origSend.apply(this, arguments);

          var xhr = this;
          var matchKey = this._mergeMatch;

          downloadAndMerge(matchKey).then(function(merged) {
            Object.defineProperty(xhr, "status", { get: function() { return 200; } });
            Object.defineProperty(xhr, "readyState", { get: function() { return 4; } });
            Object.defineProperty(xhr, "response", { get: function() { return merged.buffer; } });
            Object.defineProperty(xhr, "responseType", { get: function() { return "arraybuffer"; } });
            Object.defineProperty(xhr, "statusText", { get: function() { return "OK"; } });
            Object.defineProperty(xhr, "getAllResponseHeaders", { value: function() { return "content-type: application/octet-stream\r\ncontent-length: " + merged.byteLength + "\r\n"; } });
            Object.defineProperty(xhr, "getResponseHeader", { value: function(h) {
              if (h.toLowerCase() === "content-length") return "" + merged.byteLength;
              if (h.toLowerCase() === "content-type") return "application/octet-stream";
              return null;
            }});

            if (typeof xhr.onprogress === "function") {
              xhr.onprogress({ loaded: merged.byteLength, total: merged.byteLength, lengthComputable: true });
            }
            if (typeof xhr.onload === "function") {
              xhr.onload({ target: xhr });
            }
            if (typeof xhr.onreadystatechange === "function") {
              xhr.onreadystatechange();
            }
            try { xhr.dispatchEvent(new Event("load")); } catch(e) {}
          }).catch(function(err) {
            console.error("[MERGE-XHR] " + matchKey + " HATA:", err);
            if (typeof xhr.onerror === "function") xhr.onerror(err);
          });
        };
      })();
    </script>

    <script>
      var buildUrl = "https://cdn.jsdelivr.net/gh/okyesgoogl/sp557xxd@main/Build";
      var loaderUrl = buildUrl + "/Build.loader.js";
      var config = {
        dataUrl: buildUrl + "/Build.data",
